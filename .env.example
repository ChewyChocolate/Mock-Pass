# Mock Pass — environment variables.
# Copy this file to `.env.local` and fill in real values for local dev.
# For Vercel deployments, set these in Project Settings → Environment Variables.

# --- Backend (Supabase) ---
# Required to enable sign-in, sign-up, and cross-device history sync.
# See README "Backend setup" for where to find these.
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR-PUBLIC-ANON-KEY"

# --- Error tracking (Sentry, optional) ---
# When set, errors and session replays are sent to your Sentry project.
# Leave unset to disable Sentry entirely. The Vercel Sentry integration
# auto-populates this on deploy.
# VITE_SENTRY_DSN="https://YOUR-SENTRY-KEY@oXXXXXX.ingest.sentry.io/PROJECT-ID"
